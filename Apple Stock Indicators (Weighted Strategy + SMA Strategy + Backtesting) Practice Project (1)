    "import numpy as np\n",
    "\n",
    "# -----------------------------\n",
    "# 1. FEATURE ENGINEERING (INPUTS)\n",
    "# assumes df already has: Adj Close\n",
    "# -----------------------------\n",
    "df[\"SMA20\"] = df[\"Adj Close\"].rolling(20).mean()\n",
    "df[\"SMA50\"] = df[\"Adj Close\"].rolling(50).mean()\n",
    "\n",
    "delta = df[\"Adj Close\"].diff()\n",
    "gain = delta.clip(lower=0)\n",
    "loss = -delta.clip(upper=0)\n",
    "avg_gain = gain.rolling(14).mean()\n",
    "avg_loss = loss.rolling(14).mean()\n",
    "rs = avg_gain / avg_loss\n",
    "df[\"RSI\"] = 100 - (100 / (1 + rs))\n",
    "\n",
    "df[\"EMA12\"] = df[\"Adj Close\"].ewm(span=12, adjust=False).mean()\n",
    "df[\"EMA26\"] = df[\"Adj Close\"].ewm(span=26, adjust=False).mean()\n",
    "df[\"MACD\"] = df[\"EMA12\"] - df[\"EMA26\"]\n",
    "df[\"SignalLine\"] = df[\"MACD\"].ewm(span=9, adjust=False).mean()\n",
    "\n",
    "# -----------------------------\n",
    "# 2. SIGNAL GENERATION (MODEL LOGIC)\n",
    "# -----------------------------\n",
    "# SMA crossover signal\n",
    "df[\"Signal_MA\"] = 0\n",
    "df.loc[df[\"SMA20\"] > df[\"SMA50\"], \"Signal_MA\"] = 1\n",
    "df.loc[df[\"SMA20\"] < df[\"SMA50\"], \"Signal_MA\"] = -1\n",
    "\n",
    "# MACD signal\n",
    "df[\"Signal_MACD\"] = 0\n",
    "df.loc[df[\"MACD\"] > df[\"SignalLine\"], \"Signal_MACD\"] = 1\n",
    "df.loc[df[\"MACD\"] < df[\"SignalLine\"], \"Signal_MACD\"] = -1\n",
    "\n",
    "# RSI signal\n",
    "df[\"Signal_RSI\"] = 0\n",
    "df.loc[df[\"RSI\"] < 30, \"Signal_RSI\"] = 1\n",
    "df.loc[df[\"RSI\"] > 70, \"Signal_RSI\"] = -1\n",
    "\n",
    "# Weighted model: combine signals\n",
    "df[\"Signal\"] = (\n",
    "    0.5 * df[\"Signal_MA\"] +\n",
    "    0.3 * df[\"Signal_MACD\"] +\n",
    "    0.2 * df[\"Signal_RSI\"]\n",
    ")\n",
    "\n",
    "# Turn into discrete trading signal: -1, 0, 1\n",
    "df[\"Signal\"] = df[\"Signal\"].apply(lambda x: 1 if x > 0 else (-1 if x < 0 else 0))\n",
    "\n",
    "# -----------------------------\n",
    "# 3. POSITION SIZING (WHAT YOU HOLD)\n",
    "# -----------------------------\n",
    "# avoid look-ahead bias: act on yesterday's signal\n",
    "df[\"Position\"] = df[\"Signal\"].shift(1)\n",
    "\n",
    "# optional: volatility-adjusted sizing\n",
    "df[\"Volatility20\"] = df[\"Return\"].rolling(20).std()\n",
    "df[\"VolAdjPosition\"] = (df[\"Signal\"] / df[\"Volatility20\"]).clip(-1, 1)\n",
    "df[\"VolAdjPosition\"] = df[\"VolAdjPosition\"].shift(1)\n"
